---
import Layout from "../layouts/Layout.astro";

const bookingUrl = "https://calendly.com/chris-smarttechventures/chat-with-us-1";

const partners = [
  { src: "/images/microsoft-partner-network.jpg", alt: "Microsoft partner", h: "h-12" },
  { src: "/images/solutions/aws-parner-logo.jpg", alt: "AWS partner", h: "h-12" },
  { src: "/images/solutions/gcp-partner.png", alt: "Google Cloud partner", h: "h-9" },
  { src: "/images/solutions/github-partner.png", alt: "GitHub partner", h: "h-12" },
  { src: "/images/solutions/d365.jpg", alt: "Dynamics 365", h: "h-8" },
  { src: "/images/solutions/Salesforce.jpg", alt: "Salesforce", h: "h-12" },
];

const team = [
  {
    name: "Chris McKelt",
    title: "Principal Consultant",
    description:
      "20+ years of working in the IT industry delivering solutions to clients that help them succeed.",
    profile: "/team/profile_small.jpg",
    link: "https://www.linkedin.com/in/chrismckelt/",
  },
  {
    name: "Tracy Dallas",
    title: "Talent Partner",
    description:
      "15+ years of experience in project management and team leadership. Strong organizational and communication skills.",
    profile: "/team/tracy.jpg",
    link: "",
  },
  {
    name: "Lachlan James",
    title: "Data Engineer",
    description: "12+ years of experience in data architecture.",
    profile: "/team/ljm.jpg",
    link: "https://www.linkedin.com/in/lachlan-james-1611572b2/",
  },
];

// Smart Tech About Us content — preserved verbatim
const paragraphs = [
  "Boutique AI Architecture Agency. End to end. Vendor agnostic. Customer focused.",
  "We are a small, senior team of AI and data architects with deep delivery experience across energy, mining, government, finance, and media. We don't do superficial strategy decks — we design and build AI systems that work in production.",
  "Our approach is vendor agnostic: we recommend the best tool for your problem, not the one tied to a partnership incentive. We work with Azure, AWS, GCP, and the leading open-source AI ecosystem — selecting what fits your context, budget, and team.",
  "From AI strategy and architecture through to agentic systems, data platforms, and MLOps pipelines — we take full ownership of the outcome, not just the advice.",
];
---

<Layout
  title="About Us | Smart Tech"
  description="Smart Tech is a boutique AI architecture agency — a small, senior team of AI and data architects designing and building AI systems that work in production."
>
  <!-- About hero -->
  <section class="relative overflow-hidden border-b border-slate-200/70 py-14 sm:py-20">
    <div class="mx-auto w-full max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-[1fr_0.9fr] lg:items-center">
        <div class="space-y-8 fade-up">
          <span class="eyebrow">About Us</span>
          <h1 class="font-display text-5xl font-semibold leading-[1.05] sm:text-6xl">
            Boutique AI Architecture Agency.
          </h1>
          <p class="max-w-2xl text-lg leading-8 text-slate-600 sm:text-xl">
            End to end. Vendor agnostic. Customer focused.
          </p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href={bookingUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 text-sm font-extrabold transition duration-200 border border-accent-300 bg-accent-400 text-ink shadow-soft hover:-translate-y-0.5 hover:border-accent-200 hover:bg-accent-300"
            >
              <span>Book a consultation</span>
              <span aria-hidden="true">-&gt;</span>
            </a>
            <a
              href="/contact"
              class="inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 text-sm font-extrabold transition duration-200 border border-slate-300 bg-white text-slate-950 hover:-translate-y-0.5 hover:border-brand-400 hover:text-brand-700"
            >
              <span>Contact us</span>
              <span aria-hidden="true">-&gt;</span>
            </a>
          </div>
        </div>

        <div class="fade-up" style="--delay: 120ms;">
          <div class="dark-panel relative overflow-hidden p-6 sm:p-8">
            <div class="absolute inset-0 grid-outline opacity-40"></div>
            <div class="relative space-y-5">
              <p class="panel-label">How we work</p>
              <ul class="space-y-4">
                <li class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                  <p class="text-sm font-semibold text-white">Senior team only</p>
                  <p class="mt-1 text-sm text-slate-300">
                    AI and data architects with production delivery experience.
                  </p>
                </li>
                <li class="rounded-lg border border-white/10 bg-white/[0.04] p-4 sm:ml-8">
                  <p class="text-sm font-semibold text-white">Vendor agnostic</p>
                  <p class="mt-1 text-sm text-slate-300">
                    The best tool for your problem — Azure, AWS, GCP, or open source.
                  </p>
                </li>
                <li class="rounded-lg border border-white/10 bg-white/[0.04] p-4">
                  <p class="text-sm font-semibold text-white">Full ownership</p>
                  <p class="mt-1 text-sm text-slate-300">
                    Strategy, architecture, agentic systems, data platforms, and MLOps.
                  </p>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About narrative -->
  <section class="section-shell">
    <div class="mx-auto w-full max-w-3xl px-6 sm:px-8 lg:px-12 space-y-6">
      {
        paragraphs.slice(1).map((p) => (
          <p class="text-lg leading-8 text-slate-700">{p}</p>
        ))
      }
    </div>
  </section>

  <!-- Team -->
  <section id="team" class="section-shell pt-0 scroll-mt-24">
    <div class="mx-auto w-full max-w-7xl px-6 sm:px-8 lg:px-12 space-y-10">
      <div class="space-y-5 max-w-4xl">
        <span class="eyebrow">Team</span>
        <h2 class="font-display text-3xl font-semibold leading-tight sm:text-4xl lg:text-5xl">
          Senior practitioners who own the outcome.
        </h2>
        <p class="max-w-3xl text-base leading-8 text-slate-600 sm:text-lg">
          We have delivered AI and data solutions across energy, mining, finance, government, and
          media — and we stay hands-on from strategy through to production.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {
          team.map((member, i) => (
            <article class="surface-panel fade-up h-full p-7" style={`--delay:${i * 80}ms;`}>
              <div class="flex h-full flex-col gap-5">
                <div class="flex items-center gap-4">
                  <img
                    src={member.profile}
                    alt={member.name}
                    loading="lazy"
                    class="h-20 w-20 rounded-lg border border-slate-200 object-cover"
                  />
                  <div class="space-y-1">
                    <p class="panel-label">{member.title}</p>
                    <h3 class="font-display text-xl font-semibold text-slate-950">{member.name}</h3>
                  </div>
                </div>
                <div class="h-1 w-16 bg-accent-400" />
                <p class="text-sm leading-7 text-slate-600">{member.description}</p>
                {member.link && (
                  <a
                    href={member.link}
                    target="_blank"
                    rel="noreferrer"
                    class="mt-auto inline-flex items-center gap-2 text-sm font-extrabold text-brand-700 hover:text-brand-800"
                  >
                    Connect on LinkedIn
                    <span aria-hidden="true">-&gt;</span>
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="section-shell pt-0">
    <div class="mx-auto w-full max-w-7xl px-6 sm:px-8 lg:px-12 space-y-8">
      <div class="space-y-4 max-w-3xl">
        <span class="eyebrow">Ecosystem</span>
        <h2 class="font-display text-3xl font-semibold sm:text-4xl">
          Partnered across the platforms that matter.
        </h2>
      </div>
      <div class="surface-panel p-8">
        <div class="grid grid-cols-2 items-center gap-8 sm:grid-cols-3 md:grid-cols-6">
          {
            partners.map((p) => (
              <div class="flex grayscale transition duration-200 hover:grayscale-0">
                <img src={p.src} class={`${p.h} w-auto mx-auto`} loading="lazy" alt={p.alt} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
