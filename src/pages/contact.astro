---
import Layout from "../layouts/Layout.astro";

const bookingUrl = "https://calendly.com/chris-smarttechventures/chat-with-us-1";
---

<Layout
  title="Contact | Smart Tech"
  description="Get in touch with Smart Tech to discuss AI solutions, agentic workflows, process automation, and workforce transformation."
>
  <section class="relative overflow-hidden border-b border-slate-200/70 py-14 sm:py-16">
    <div class="mx-auto w-full max-w-7xl px-6 sm:px-8 lg:px-12">
      <div class="grid gap-10 lg:grid-cols-[1fr_1.1fr] lg:items-start">
        <div class="space-y-6 fade-up">
          <span class="eyebrow">Contact</span>
          <h1 class="font-display text-4xl font-semibold leading-tight sm:text-5xl">Contact Us</h1>
          <p class="max-w-md text-lg leading-8 text-slate-600">
            Tell us about the operational problem you want to solve and we'll come back to you with a
            practical, controlled path forward.
          </p>
          <div class="surface-panel space-y-4 p-6">
            <div>
              <p class="panel-label">Phone</p>
              <a
                href="tel:+61426972312"
                class="mt-2 block font-display text-2xl font-semibold text-slate-950 hover:text-brand-700"
              >
                0426 972 312
              </a>
            </div>
            <div class="border-t border-slate-200 pt-4">
              <p class="panel-label">Prefer to book a time?</p>
              <a
                href={bookingUrl}
                target="_blank"
                rel="noreferrer"
                class="mt-3 inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 text-sm font-extrabold transition duration-200 border border-accent-300 bg-accent-400 text-ink shadow-soft hover:-translate-y-0.5 hover:border-accent-200 hover:bg-accent-300"
              >
                <span>Book a Consultation</span>
                <span aria-hidden="true">-&gt;</span>
              </a>
            </div>
          </div>
        </div>

        <div class="fade-up" style="--delay: 100ms;">
          <div class="surface-panel overflow-hidden p-4 sm:p-6">
            <iframe
              id="JotFormIFrame-241127131294852"
              title="Contact Us"
              onload="window.parent.scrollTo(0,0)"
              allowtransparency="true"
              allow="geolocation; microphone; camera; fullscreen"
              src="https://form.jotform.com/241127131294852"
              style="min-width:100%;max-width:100%;height:800px;border:none;border-radius:0.5rem;"
            >
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script src="https://cdn.jotfor.ms/s/umd/latest/for-form-embed-handler.js"></script>
  <script is:inline>
    window.jotformEmbedHandler(
      "iframe[id='JotFormIFrame-241127131294852']",
      "https://form.jotform.com/"
    );
  </script>
</Layout>
