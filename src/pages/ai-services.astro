---
import Container from "../components/Container.astro"
import Layout from '../layouts/Layout.astro';

const capabilities = [
  {
    name1: "Requirements & Principles",
    name2: "/requirements · /principles",
    body: "We turn ambiguous AI ambition into testable business and technical requirements, anchored to a set of architecture principles your whole team can hold the line on.",
    background: "min-h-[280px] p-10 bg-lime rounded-[45px] shadow border border-black text-black",
  },
  {
    name1: "Architecture Decisions",
    name2: "/adr · /hld-review · /dld-review",
    body: "Every significant choice is captured as an ADR with options analysis and traceability, then carried through high- and low-level design reviews so nothing is decided twice.",
    background: "min-h-[280px] p-10 bg-zinc-100 rounded-[45px] shadow border border-black text-black",
  },
  {
    name1: "Secure by Design",
    name2: "/secure · /dpia · /risk",
    body: "Governance baked in from day one — Secure by Design assessments, Data Protection Impact Assessments, and an Orange Book risk register, not a bolt-on at the end.",
    background: "min-h-[280px] p-10 bg-black rounded-[45px] shadow border border-black text-white",
  },
  {
    name1: "Cloud & Build vs Buy",
    name2: "/aws-research · /azure-research · /gcp-research",
    body: "Vendor-agnostic research across AWS, Azure and Google Cloud — matched to Well-Architected guidance, regional availability and a clear build-vs-buy case with TCO.",
    background: "min-h-[280px] p-10 bg-zinc-100 rounded-[45px] shadow border border-black text-black",
  },
  {
    name1: "Strategy & Roadmap",
    name2: "/strategy · /roadmap · /wardley",
    body: "We synthesise the decisions into an executive architecture strategy, a multi-year roadmap, and Wardley Maps that make the strategic play obvious to your board.",
    background: "min-h-[280px] p-10 bg-zinc-100 rounded-[45px] shadow border border-black text-black",
  },
  {
    name1: "Delivery Governance",
    name2: "/backlog · /traceability · /conformance",
    body: "From requirements straight to a prioritised backlog, a traceability matrix, and ongoing conformance checks that prove what got built matches what was agreed.",
    background: "min-h-[280px] p-10 bg-lime rounded-[45px] shadow border border-black text-black",
  },
];
---

<Layout title="AI Services — Smart Tech">
  <main class="space-y-20">

    <!-- Hero -->
    <Container>
      <div class="relative flex flex-col items-center md:flex-row" id="ai-services">
        <div class="row items-center py-5 md:w-7/12 md:pb-20 md:pt-10">
          <div class="text-left space-y-5">
            <div class="inline-block px-4 py-1.5 bg-lime rounded-full text-sm font-medium">Powered by ArcKit</div>
            <h1 class="text-5xl font-medium leading-none md:text-6xl">AI Services, Governed End to End</h1>
            <p class="mt-6 text-xl font-normal leading-7">
              We are ArcKit experts. <a href="https://arckit.org" target="_blank" rel="noopener noreferrer" class="underline decoration-lime decoration-4 underline-offset-4">arckit.org</a> is the
              architecture governance toolkit we use to take AI projects from first principles to production —
              with every requirement, decision, risk and design traceable, reviewable, and built to public-sector grade standards.
            </p>
            <p class="text-xl font-normal leading-7">
              It means you don't get a glossy strategy deck and a shrug. You get architecture artefacts that
              survive scrutiny — and a system that actually ships.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 pt-2">
              <a class="px-9 py-5 bg-zinc-900 hover:bg-white text-white hover:text-black border rounded-2xl inline-flex" href="/contact" target="_self">
                <h2 class="text-center text-xl font-normal leading-7">Book a consultation</h2>
              </a>
              <a class="px-9 py-5 bg-lime hover:bg-zinc-900 text-black hover:text-white border border-black rounded-2xl inline-flex" href="https://arckit.org" target="_blank" rel="noopener noreferrer">
                <h2 class="text-center text-xl font-normal leading-7">Explore ArcKit</h2>
              </a>
            </div>
          </div>
        </div>
        <div class="flex items-center py-5 md:w-5/12 md:pb-20 md:pt-10">
          <img src="/services/Illustration.svg" width="100%" alt="AI architecture governance with ArcKit" />
        </div>
      </div>
    </Container>

    <!-- Why ArcKit -->
    <Container>
      <div class="relative flex flex-col items-center md:flex-row">
        <div class="row items-center py-5 md:pr-20 md:w-3/12 md:py-10">
          <div class="text-left space-y-3 bg-lime">
            <h2 class="text-4xl font-medium leading-none sm:text-6xl">Why ArcKit</h2>
          </div>
        </div>
        <div class="flex items-center py-5 md:w-9/12 md:py-10">
          <p class="text-xl font-normal leading-7 text-left">
            ArcKit gives architecture the same rigour engineers expect from code — versioned artefacts, traceability from
            requirement to design to test, and assessments mapped to recognised standards. We've made it the backbone of
            how we deliver AI, so governance accelerates the work instead of slowing it down.
          </p>
        </div>
      </div>
    </Container>

    <!-- Capability cards -->
    <Container>
      <div class="flex-row items-center py-5">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {
          capabilities.map(({ background, name1, name2, body }) => (
          <div class={background}>
            <div class="flex flex-col justify-start items-start gap-3 h-full">
              <div class="text-3xl font-medium">{name1}</div>
              <div class="text-sm font-medium opacity-70 font-mono">{name2}</div>
              <div class="text-lg font-normal leading-7 pt-2">{body}</div>
            </div>
          </div>
          ))
          }
        </div>
      </div>
    </Container>

    <!-- CTA -->
    <Container>
      <div class="flex-row items-center my-6 p-14 bg-zinc-100 rounded-[45px]">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-center">
          <div class="flex-col justify-start items-start gap-[26px] inline-flex text-black">
            <div class="text-3xl font-medium">Want governed AI delivery?</div>
            <div class="text-lg font-normal">Tell us where you want to go. We'll architect the path with ArcKit — from first conversation to a live, assured system.</div>
            <a href="/contact" class="px-[35px] py-5 bg-zinc-900 rounded-[14px] inline-flex">
              <div class="text-center text-white text-xl font-normal leading-7">Get your free AI assessment</div>
            </a>
          </div>
          <div class="hidden md:grid justify-items-center -m-10">
            <img src="/services/Illustration.svg" width="55%" alt="ArcKit governed delivery" />
          </div>
        </div>
      </div>
    </Container>

  </main>
</Layout>
