---
const articlesUrl = "https://blog.smarttechventures.au";

const exploreLinks = [
  { href: "/", label: "Home" },
  { href: "/#services", label: "Services" },
  { href: "/#use-cases", label: "Solutions" },
  { href: "https://axurcio.com", label: "Axurcio", external: true },
  { href: "/about", label: "About" },
  { href: articlesUrl, label: "Insights", external: true },
  { href: "/contact", label: "Contact" },
];

const serviceLinks = [
  { href: "/#ai-solutions", label: "AI Solutions" },
  { href: "/#agentic-workflows", label: "Agentic Workflows" },
  { href: "/#process-automation", label: "Process Automation" },
  { href: "/#workforce-transformation", label: "Workforce Transformation" },
];

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-white/10 bg-ink pb-10 pt-14 text-white">
  <div class="mx-auto w-full max-w-7xl px-6 sm:px-8 lg:px-12 space-y-12">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_0.7fr_0.9fr]">
      <div class="space-y-5">
        <a href="/" class="flex items-center gap-3">
          <span
            class="relative flex h-11 w-11 items-center justify-center overflow-hidden rounded-lg bg-white text-sm font-black text-ink"
          >
            <span class="absolute inset-x-0 bottom-0 h-1.5 bg-accent-400"></span>
            <span class="relative">ST</span>
          </span>
          <div class="space-y-0.5">
            <span class="block font-display text-lg font-semibold text-white">Smart Tech</span>
            <span class="block text-xs uppercase tracking-[0.22em] text-slate-400">
              AI architecture at scale
            </span>
          </div>
        </a>
        <p class="max-w-xl text-base leading-8 text-slate-300">
          Smart Tech helps enterprises and government teams move from manual processes to autonomous
          systems through AI solutions, agentic workflows, and workforce transformation.
        </p>
      </div>

      <div class="space-y-4">
        <h3 class="panel-label">Explore</h3>
        <ul class="space-y-3">
          {
            exploreLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noreferrer" : undefined}
                  class="text-sm text-slate-300 hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="space-y-4">
        <h3 class="panel-label">Services</h3>
        <ul class="space-y-3">
          {
            serviceLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-slate-300 hover:text-white">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="space-y-3 pt-3">
          <a href="/contact" class="block text-sm text-slate-300 hover:text-white">
            Contact us — 0426 972 312
          </a>
          <a
            href="https://www.linkedin.com/company/smart-tech-au"
            target="_blank"
            rel="noreferrer"
            class="block text-sm text-slate-300 hover:text-white"
          >
            LinkedIn
          </a>
          <a
            href="https://twitter.com/smarttechau"
            target="_blank"
            rel="noreferrer"
            class="block text-sm text-slate-300 hover:text-white"
          >
            X / Twitter
          </a>
          <a href="/terms" class="block text-sm text-slate-300 hover:text-white">Terms</a>
        </div>
      </div>
    </div>

    <div
      class="flex flex-col gap-3 border-t border-white/10 pt-6 text-sm text-slate-400 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {year} Smart Tech. All rights reserved.</p>
      <p>AI solutions, agentic workflows, and transformation delivery for complex organisations.</p>
    </div>
  </div>
</footer>
