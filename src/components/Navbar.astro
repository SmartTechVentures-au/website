---
const bookingUrl = "https://calendly.com/chris-smarttechventures/chat-with-us-1";
const articlesUrl = "https://blog.smarttechventures.au";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/#services", label: "Services" },
  { href: "/#use-cases", label: "Solutions" },
  { href: "https://axurcio.com", label: "Axurcio", external: true },
  { href: "/about", label: "About" },
  { href: articlesUrl, label: "Insights", external: true },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/92 text-slate-950 backdrop-blur-xl"
>
  <div class="mx-auto w-full max-w-7xl px-6 sm:px-8 lg:px-12 py-3">
    <div class="flex items-center justify-between gap-6">
      <a href="/" class="group flex items-center gap-3" aria-label="Smart Tech home">
        <span
          class="relative flex h-10 w-10 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-ink text-sm font-black text-white shadow-soft"
        >
          <span class="absolute inset-x-0 bottom-0 h-1.5 bg-accent-400"></span>
          <span class="relative">ST</span>
        </span>
        <div class="space-y-0.5">
          <span class="block font-display text-lg font-semibold text-slate-950">Smart Tech</span>
          <span
            class="block text-xs uppercase tracking-[0.22em] text-slate-600 group-hover:text-brand-700"
          >
            AI Architecture
          </span>
        </div>
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-950 md:hidden"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span class="sr-only">Toggle navigation</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path
            fill-rule="evenodd"
            d="M3 5h14v2H3V5Zm0 4h14v2H3V9Zm0 4h14v2H3v-2Z"
            clip-rule="evenodd"></path>
        </svg>
      </button>

      <nav
        id="nav-menu"
        class="absolute left-6 right-6 top-full hidden rounded-lg border border-slate-200 bg-white p-4 shadow-soft md:static md:flex md:flex-1 md:items-center md:justify-between md:border-0 md:bg-transparent md:p-0 md:shadow-none"
      >
        <ul class="flex flex-col gap-2 md:flex-row md:items-center md:gap-1">
          {
            navLinks.map((link) => {
              const isActive =
                link.href === "/"
                  ? currentPath === "/"
                  : !link.external && currentPath.startsWith(link.href.split("#")[0]) &&
                    link.href !== "/";
              return (
                <li>
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noreferrer" : undefined}
                    class={`inline-flex rounded-md px-3 py-2 text-sm font-semibold transition ${
                      isActive
                        ? "bg-ink text-white"
                        : "text-slate-700 hover:bg-slate-100 hover:text-slate-950"
                    }`}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
        <div class="mt-4 md:mt-0">
          <a
            href={bookingUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-md px-5 py-3 text-sm font-extrabold transition duration-200 border border-accent-300 bg-accent-400 text-ink shadow-soft hover:-translate-y-0.5 hover:border-accent-200 hover:bg-accent-300 w-full md:w-auto"
          >
            <span>Book a Consultation</span>
            <span aria-hidden="true">-&gt;</span>
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      menu.classList.toggle("hidden");
    });
    menu.querySelectorAll("a").forEach((link) =>
      link.addEventListener("click", () => {
        if (window.innerWidth < 768) {
          toggle.setAttribute("aria-expanded", "false");
          menu.classList.add("hidden");
        }
      })
    );
  }
</script>
