---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Smart Tech — Boutique AI Architecture Agency",
  description = "Smart Tech designs enterprise AI systems, agentic workflows, and operational transformation programs that help organisations move faster with intelligent automation.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="author" content="Smart Tech" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#061412" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="keywords"
      content="AI architecture, AI strategy, agentic workflows, process automation, workforce transformation, data mesh, LLM, machine learning, cloud AI, Azure, AWS, GCP, Perth, Australia"
    />
    <link rel="canonical" href="https://smarttechventures.au" />
    <link rel="icon" type="image/x-icon" href="/images/favicon.png" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://smarttechventures.au" />
    <meta property="og:site_name" content="Smart Tech" />
    <meta property="og:image" content="https://smarttechventures.au/images/logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@SmartTechAU" />
    <meta name="twitter:creator" content="@SmartTechAU" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://smarttechventures.au/images/logo.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts: Manrope (body) + Sora (display) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-01MGQXJNBV"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-01MGQXJNBV");
    </script>
  </head>
  <body class="font-sans">
    <div class="relative isolate overflow-x-clip">
      <Navbar />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <!-- Legacy Google Analytics (ga.js) -->
    <script is:inline type="text/javascript">
      var _gaq = _gaq || [];
      _gaq.push(["_setAccount", "UA-9649471-5"]);
      _gaq.push(["_trackPageview"]);

      (function () {
        var ga = document.createElement("script");
        ga.type = "text/javascript";
        ga.async = true;
        ga.src =
          ("https:" == document.location.protocol ? "https://ssl" : "http://www") +
          ".google-analytics.com/ga.js";
        var s = document.getElementsByTagName("script")[0];
        s.parentNode.insertBefore(ga, s);
      })();
    </script>

    <!-- Calendly badge widget begin -->
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    <script
      is:inline
      src="https://assets.calendly.com/assets/external/widget.js"
      type="text/javascript"
      async></script>
    <script is:inline type="text/javascript">
      window.addEventListener("load", function () {
        if (window.Calendly) {
          Calendly.initBadgeWidget({
            url: "https://calendly.com/chris-smarttechventures/chat-with-us-1",
            text: "Schedule a chat",
            color: "#b9ff66",
            textColor: "#061412",
            branding: undefined,
          });
        }
      });
    </script>
    <!-- Calendly badge widget end -->
  </body>
</html>
